# Port configuration
PORT=5000

# MongoDB URI connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/recapped

# JWT Secret for user session tokens
JWT_SECRET=your_jwt_secret_key

# Groq API key for Llama and Whisper engines
GROQ_API_KEY=your_groq_api_key

# ==============================================================================
# Notion Integration Settings
# ==============================================================================
# Required. The client ID of your Notion integration.
# Obtain from the integration dashboard at https://www.notion.so/my-integrations
NOTION_CLIENT_ID=39ad872b-594c-81ae-96df-00378de5629f

# Required. The client secret of your Notion integration.
# Obtain from the integration dashboard at https://www.notion.so/my-integrations
NOTION_CLIENT_SECRET=your_notion_client_secret

# Required. The redirect URI configured for your Notion integration.
# This must match one of the redirect URIs in notion.so/my-integrations.
# For local testing, use: http://localhost:5000/api/integrations/notion/callback
NOTION_REDIRECT_URI=http://localhost:5000/api/integrations/notion/callback

# Required. A 32-byte encryption key used to encrypt the access token at rest.
# Generate a secure key locally, e.g. by running:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NOTION_ENCRYPTION_KEY=your_32_byte_hex_encryption_key
